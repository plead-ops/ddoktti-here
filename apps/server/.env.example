# ── Slack 앱 (관리자 1회 발급) ───────────────────────────────
SLACK_APP_TOKEN=xapp-...            # App-Level Token (connections:write, Socket Mode)
SLACK_BOT_TOKEN=xoxb-...            # Bot token (운영 최소 스코프)
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
SLACK_SIGNING_SECRET=...

# ── 서버 ────────────────────────────────────────────────────
PORT=8787
PUBLIC_BASE_URL=https://ddoktti-here.app.plead.co.kr
SESSION_TTL_SECONDS=2592000        # 30d

# user token 암호화 키 (32바이트 base64). 가능하면 서버와 분리 보관/주입.
TOKEN_ENC_KEY=base64:CHANGEME_32_BYTES

# ── 데이터 저장소 ────────────────────────────────────────────
# 로컬(docker-compose.yml): localhost. 운영(Dokploy): 내부 컨테이너 호스트명.
DATABASE_URL=postgres://ddoktti:ddoktti_local@localhost:5432/ddoktti
REDIS_URL=redis://localhost:6379

# ── 로깅 ────────────────────────────────────────────────────
LOG_LEVEL=info
