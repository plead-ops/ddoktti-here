{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "똑띠왔어요",
  "version": "0.1.1",
  "identifier": "kr.co.plead.ddoktti-here",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: http://asset.localhost https://*.slack-edge.com https://*.gravatar.com https://lh3.googleusercontent.com; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ddoktti-here.app.plead.co.kr"
    },
    "windows": [
      {
        "label": "settings",
        "title": "똑띠왔어요 설정",
        "url": "index.html",
        "width": 740,
        "height": 550,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 360,
        "height": 360,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "focus": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Plead",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Korean"]
      }
    }
  },
  "plugins": {}
}
