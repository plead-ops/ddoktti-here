{
  "name": "ddoktti-here",
  "private": true,
  "version": "0.1.0",
  "description": "똑띠왔어요 — 슬랙 알림 오버레이 데스크탑 앱 (서버 + 클라이언트 모노레포)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev:server": "pnpm --filter @ddoktti/server dev",
    "dev:desktop": "pnpm --filter @ddoktti/desktop dev",
    "tauri": "pnpm --filter @ddoktti/desktop tauri",
    "icons": "pnpm --filter @ddoktti/desktop tauri icon ../../assets/icons/app-icon-1024.png"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
