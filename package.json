{
  "name": "ddoktti-here",
  "private": true,
  "version": "0.1.5",
  "description": "똑띠왔어요 — 윈도우 슬랙 알림 감지 오버레이 데스크탑 앱",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev:desktop": "pnpm --filter @ddoktti/desktop dev",
    "tauri": "pnpm --filter @ddoktti/desktop tauri",
    "icons": "pnpm --filter @ddoktti/desktop tauri icon ../../assets/icons/app-icon-1024.png"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
